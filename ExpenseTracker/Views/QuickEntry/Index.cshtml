            function openEditModal(id, pin) {
                const $btn = $(`.edit-btn[data-id="${id}"]`);
                
                $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status"></span>');

                $.get('@Url.Action("GetTransaction", "QuickEntry")', { id: id, pin: pin }, function(data) {
                    $('#editId').val(data.id);
                    $('#editDate').val(data.date);
                    $('#editType').val(data.type);
                    $('#editAmount').val(data.amount);
                    $('#editAccountSourceId').val(data.accountSourceId);
                    $('#editCategoryId').val(data.categoryId);
