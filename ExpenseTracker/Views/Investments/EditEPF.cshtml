@model ExpenseTracker.Models.EPF
@{
    Layout = null;
}

<div class="modal-header border-0 pb-0">
    <h5 class="modal-title fw-bold text-success"><i class="bi bi-wallet2 me-2"></i>Edit EPF Account</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<form asp-action="EditEPF" method="post" id="editEpfForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="UserId" />
    
    <div class="modal-body py-4">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="UAN" class="form-label fw-bold small text-uppercase">UAN / Account Number</label>
                <input asp-for="UAN" class="form-control shadow-sm rounded-3" required />
                <span asp-validation-for="UAN" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="MemberId" class="form-label fw-bold small text-uppercase">Member ID (Optional)</label>
                <input asp-for="MemberId" class="form-control shadow-sm rounded-3" />
                <span asp-validation-for="MemberId" class="text-danger small"></span>
            </div>
            <div class="col-md-12">
                <label asp-for="EmployeeContribution" class="form-label fw-bold small text-uppercase">Total Employee Contribution (Your Invested Capital)</label>
                <input asp-for="EmployeeContribution" class="form-control shadow-sm rounded-3" type="number" step="0.01" required />
                <span asp-validation-for="EmployeeContribution" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="EmployerContribution" class="form-label fw-bold small text-uppercase">Total Employer Contribution</label>
                <input asp-for="EmployerContribution" class="form-control shadow-sm rounded-3" type="number" step="0.01" required />
                <span asp-validation-for="EmployerContribution" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="InterestEarned" class="form-label fw-bold small text-uppercase">Total Accumulated Interest</label>
                <input asp-for="InterestEarned" class="form-control shadow-sm rounded-3" type="number" step="0.01" required />
                <span asp-validation-for="InterestEarned" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="TransferIn" class="form-label fw-bold small text-uppercase">Transferred In (Previous Accounts)</label>
                <input asp-for="TransferIn" class="form-control shadow-sm rounded-3" type="number" step="0.01" required />
                <span asp-validation-for="TransferIn" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="PurchaseDate" class="form-label fw-bold small text-uppercase">Statement Update Date</label>
                <input asp-for="PurchaseDate" class="form-control shadow-sm rounded-3" type="date" value="@(Model.PurchaseDate.ToString("yyyy-MM-dd"))" />
                <span asp-validation-for="PurchaseDate" class="text-danger small"></span>
            </div>
        </div>
    </div>
    <div class="modal-footer border-0 pt-0">
        <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-success text-white rounded-pill px-4 fw-bold shadow">
            <i class="bi bi-save me-2"></i> Save Changes
        </button>
    </div>
</form>
