            function updateParentCategoryDropdown() {
                const select = $('#parentCategoryId');
                const currentVal = select.val();
                select.empty().append('<option value="">-- None (Top Level) --</option>');
                categoriesData.forEach(c => {
                    // Prevent setting a category as its own parent in the dropdown if editing
                    const editingId = $('#categoryId').val();
                    if (!editingId || c.id != editingId) {
                        select.append(`<option value="${c.id}">${c.name}</option>`);
                    }
                });
                select.val(currentVal);
            }

            function resetCategoryForm() {
                $('#categoryId').val('');
                $('#categoryName').val('');
                $('#parentCategoryId').val('');
                $('#categoryFormTitle').text('Add New Category');
                $('#categoryCancelBtnContainer').hide();
                $('#categorySubmitBtn').text('Save');
                updateParentCategoryDropdown();
            }

            $('#cancelCategoryEditBtn').on('click', function() {
                resetCategoryForm();
                $('#categoryAlertPlaceholder').empty();
            });

            $(document).on('click', '.edit-category-btn', function() {
                const btn = $(this);
                $('#categoryId').val(btn.data('id'));
                $('#categoryName').val(btn.data('name'));
                
