@model ExpenseTracker.Models.InvestmentsViewModel

@{
    ViewData["Title"] = "My Investments";
    var activeTab = Model.ActiveTab;
}

<div class="container-fluid py-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Header Summary Section -->
    <div id="summary-container">
        <partial name="_InvestmentSummary" model="Model" />
    </div>

    <!-- Actions Bar -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0 text-dark">Portfolio Details</h4>
        <div class="d-flex gap-2">
            <div id="stocks-actions" class="d-flex gap-2" style="display: @(activeTab == "Stocks" ? "flex" : "none") !important;">
                <button type="button" class="btn btn-outline-success rounded-pill px-4 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#importStocksModal">
                    <i class="bi bi-file-earmark-excel me-2"></i> Import Stocks
                </button>

                <form asp-action="RefreshAllPrices" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-primary rounded-pill px-4 fw-bold shadow-sm">
                        <i class="bi bi-arrow-clockwise me-2"></i> Refresh Prices
                    </button>
                </form>
            </div>

            <div id="mfs-actions" style="display: @(activeTab == "Mutual Funds" ? "flex" : "none") !important;">
                <button type="button" class="btn btn-outline-success rounded-pill px-4 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#importMFsModal">
                    <i class="bi bi-file-earmark-excel me-2"></i> Import Mutual Funds
                </button>
            </div>

            <a asp-action="Create" class="btn btn-primary d-flex align-items-center rounded-pill px-4 fw-bold shadow-sm">
                <i class="bi bi-plus-circle-fill me-2"></i> Add Investment
            </a>
        </div>
    </div>

    <!-- Specialized Tabs -->
    <ul class="nav nav-pills custom-pills mb-4 bg-white p-2 rounded-pill shadow-sm d-inline-flex" id="investmentTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill fw-bold @(activeTab == "Stocks" ? "active" : "") px-4" 
                    id="stocks-tab" data-bs-toggle="pill" data-bs-target="#stocks" type="button" role="tab"
                    onclick="updateSortTab('Stocks')">
                <i class="bi bi-graph-up-arrow me-2"></i> Stocks
                <span class="badge bg-light text-dark ms-2 rounded-pill">@Model.Stocks.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill fw-bold @(activeTab == "Mutual Funds" ? "active" : "") px-4" 
                    id="mfs-tab" data-bs-toggle="pill" data-bs-target="#mfs" type="button" role="tab"
                    onclick="updateSortTab('Mutual Funds')">
                <i class="bi bi-pie-chart-fill me-2"></i> Mutual Funds
                <span class="badge bg-light text-dark ms-2 rounded-pill">@Model.MutualFunds.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill fw-bold @(activeTab == "Fixed Deposits" ? "active" : "") px-4" 
                    id="fds-tab" data-bs-toggle="pill" data-bs-target="#fds" type="button" role="tab"
                    onclick="updateSortTab('Fixed Deposits')">
                <i class="bi bi-safe2-fill me-2"></i> Fixed Deposits
                <span class="badge bg-light text-dark ms-2 rounded-pill">@Model.FixedDeposits.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill fw-bold @(activeTab == "NPS" ? "active" : "") px-4" 
                    id="nps-tab" data-bs-toggle="pill" data-bs-target="#nps" type="button" role="tab"
                    onclick="updateSortTab('NPS')">
                <i class="bi bi-shield-lock-fill me-2"></i> NPS
                <span class="badge bg-light text-dark ms-2 rounded-pill">@Model.NPSs.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill fw-bold @(activeTab == "EPF" ? "active" : "") px-4" 
                    id="epf-tab" data-bs-toggle="pill" data-bs-target="#epf" type="button" role="tab"
                    onclick="updateSortTab('EPF')">
                <i class="bi bi-wallet2 me-2"></i> EPF
                <span class="badge bg-light text-dark ms-2 rounded-pill">@Model.EPFs.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill fw-bold @(activeTab == "Technical Analysis" ? "active" : "") px-4" 
                    id="ta-tab" data-bs-toggle="pill" data-bs-target="#ta" type="button" role="tab"
                    onclick="updateSortTab('Technical Analysis')">
                <i class="bi bi-cpu-fill me-2"></i> Technical Analysis
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill fw-bold @(activeTab == "Fundamental Analysis" ? "active" : "") px-4" 
                    id="fa-tab" data-bs-toggle="pill" data-bs-target="#fa" type="button" role="tab"
                    onclick="updateSortTab('Fundamental Analysis')">
                <i class="bi bi-bank2 me-2"></i> Fundamental Analysis
            </button>
        </li>
    </ul>

    <div class="tab-content" id="investmentTabsContent">
        <div class="tab-pane fade @(activeTab == "Stocks" ? "show active" : "")" id="stocks" role="tabpanel">
            <div id="stocks-container" class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <partial name="_StockTable" model="Model.Stocks" view-data="ViewData" />
            </div>
        </div>
        <div class="tab-pane fade @(activeTab == "Mutual Funds" ? "show active" : "")" id="mfs" role="tabpanel">
            <div id="mfs-container" class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <partial name="_MFTable" model="Model.MutualFunds" view-data="ViewData" />
            </div>
        </div>
        <div class="tab-pane fade @(activeTab == "Fixed Deposits" ? "show active" : "")" id="fds" role="tabpanel">
            <div id="fds-container" class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <partial name="_FDTable" model="Model.FixedDeposits" view-data="ViewData" />
            </div>
        </div>
        <div class="tab-pane fade @(activeTab == "NPS" ? "show active" : "")" id="nps" role="tabpanel">
            <div id="nps-container" class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <partial name="_NPSTable" model="Model.NPSs" view-data="ViewData" />
            </div>
        </div>
        <div class="tab-pane fade @(activeTab == "EPF" ? "show active" : "")" id="epf" role="tabpanel">
            <div id="epf-container" class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <partial name="_EPFTable" model="Model.EPFs" view-data="ViewData" />
            </div>
        </div>
        <div class="tab-pane fade @(activeTab == "Technical Analysis" ? "show active" : "")" id="ta" role="tabpanel">
            <div id="ta-container" class="card border-0 shadow-sm rounded-4 overflow-hidden pt-3">
                <div class="p-5 text-center" id="ta-loading">
                    <div class="spinner-border text-primary my-3" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="text-muted fw-bold">Analyzing your portfolio...</p>
                    <p class="text-muted small">Fetching historical market data and running indicators. This may take a few seconds.</p>
                </div>
            </div>
        </div>
        <div class="tab-pane fade @(activeTab == "Fundamental Analysis" ? "show active" : "")" id="fa" role="tabpanel">
            <div id="fa-container" class="card border-0 shadow-sm rounded-4 overflow-hidden pt-3">
                <div class="p-5 text-center" id="fa-loading">
                    <div class="spinner-border text-success my-3" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="text-muted fw-bold">Evaluating core fundamentals...</p>
                    <p class="text-muted small">Scanning P/E, Div Yield, Market Cap, ROCE, and more. This may take a few seconds.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Import Stocks Modal -->
<div class="modal fade" id="importStocksModal" tabindex="-1" aria-labelledby="importStocksModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="importStocksModalLabel">Import Stocks from Excel</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ImportStocks" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body py-4">
                    <div class="mb-3">
                        <label for="stockExcelFile" class="form-label fw-bold">Select Excel File</label>
                        <input class="form-control rounded-3" type="file" id="stockExcelFile" name="file" accept=".xlsx,.xls" required>
                        <div class="form-text mt-3">
                            <p class="mb-1"><i class="bi bi-info-circle me-1"></i> <strong>Format Requirements:</strong></p>
                            <ul class="ps-3 mb-0">
                                <li>Headers should be on <strong>Row 11</strong>.</li>
                                <li>Data should start from <strong>Row 12</strong>.</li>
                                <li>Required Columns: <code>Stock Name</code>, <code>Quantity</code>, <code>Average buy price</code>, <code>Closing price</code>.</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-toggle="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">
                        <i class="bi bi-upload me-2"></i> Upload & Import
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Import Mutual Funds Modal -->
<div class="modal fade" id="importMFsModal" tabindex="-1" aria-labelledby="importMFsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="importMFsModalLabel">Import Mutual Funds from Excel</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ImportMutualFunds" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body py-4">
                    <div class="mb-3">
                        <label for="mfExcelFile" class="form-label fw-bold">Select Excel File</label>
                        <input class="form-control rounded-3" type="file" id="mfExcelFile" name="file" accept=".xlsx,.xls" required>
                        <div class="form-text mt-3">
                            <p class="mb-1"><i class="bi bi-info-circle me-1"></i> <strong>Format Requirements:</strong></p>
                            <ul class="ps-3 mb-0">
                                <li>Headers should be on <strong>Row 21</strong>.</li>
                                <li>Data should start from <strong>Row 23</strong>.</li>
                                <li>Required Columns: <code>Folio No.</code>, <code>Units</code>, <code>Invested Value</code>, <code>Current Value</code>.</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">
                        <i class="bi bi-upload me-2"></i> Upload & Import
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div id="modal-content-placeholder">
                <div class="p-5 text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const editModal = new bootstrap.Modal(document.getElementById('editModal'));
            const modalPlaceholder = document.getElementById('modal-content-placeholder');

            // Handle clicking edit links (using event delegation)
            document.addEventListener('click', function (e) {
                const editLink = e.target.closest('.edit-investment-link');
                if (editLink) {
                    e.preventDefault();
                    const url = editLink.href;
                    
                    // Show loading spinner
                    modalPlaceholder.innerHTML = '<div class="p-5 text-center"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div></div>';
                    editModal.show();

                    // Load content via AJAX
                    fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                        .then(response => response.text())
                        .then(html => {
                            modalPlaceholder.innerHTML = html;
                            setupModalForm();
                        })
                        .catch(err => {
                            console.error('Error loading modal:', err);
                            modalPlaceholder.innerHTML = '<div class="p-4 text-center text-danger">Error loading form. Please try again.</div>';
                        });
                }
            });

            function setupModalForm() {
                const form = modalPlaceholder.querySelector('form');
                if (!form) return;

                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    const formData = new FormData(form);
                    const url = form.action;

                    fetch(url, {
                        method: 'POST',
                        body: formData,
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(response => {
                        const contentType = response.headers.get("content-type");
                        if (contentType && contentType.indexOf("application/json") !== -1) {
                            return response.json().then(data => ({ isJson: true, data }));
                        } else {
                            return response.text().then(text => ({ isJson: false, text }));
                        }
                    })
                    .then(result => {
                        if (result.isJson && result.data.success) {
                            // Success!
                            editModal.hide();
                            refreshDashboard(result.data.type);
                        } else if (!result.isJson) {
                            // Validation error - replace modal content with returned partial (which contains errors)
                            modalPlaceholder.innerHTML = result.text;
                            setupModalForm(); // Re-attach listener
                        }
                    })
                    .catch(err => {
                        console.error('Error submitting form:', err);
                    });
                });
            }

            function refreshDashboard(type) {
                // Refresh Summary
                fetch('@Url.Action("GetSummaryPartial", "Investments")')
                    .then(r => r.text())
                    .then(html => document.getElementById('summary-container').innerHTML = html);

                // Refresh target table
                let containerId = '';
                let url = '';
                if (type === 'Stock') { 
                    containerId = 'stocks-container'; 
                    url = '@Url.Action("GetStockTable", "Investments")'; 
                }
                else if (type === 'MutualFund') { 
                    containerId = 'mfs-container'; 
                    url = '@Url.Action("GetMFTable", "Investments")'; 
                }
                else if (type === 'FixedDeposit') { 
                    containerId = 'fds-container'; 
                    url = '@Url.Action("GetFDTable", "Investments")'; 
                }
                else if (type === 'NPS') {
                    containerId = 'nps-container';
                    url = '@Url.Action("GetNPSTable", "Investments")';
                }
                else if (type === 'EPF') {
                    containerId = 'epf-container';
                    url = '@Url.Action("GetEPFTable", "Investments")';
                }

                if (containerId && url) {
                    fetch(url)
                        .then(r => r.text())
                        .then(html => document.getElementById(containerId).innerHTML = html);
                }
            }

            // Technical Analysis Lazy Loading
            let taLoaded = false;
            function loadTechnicalAnalysis() {
                if (taLoaded) return;
                taLoaded = true; // prevent multiple calls
                fetch('@Url.Action("GetTechnicalAnalysis", "Investments")')
                    .then(r => r.text())
                    .then(html => {
                        document.getElementById('ta-container').innerHTML = html;
                    })
                    .catch(e => {
                        document.getElementById('ta-container').innerHTML = '<div class="p-5 text-center text-danger">Failed to load analysis.</div>';
                        taLoaded = false;
                    });
            }

            // Fundamental Analysis Lazy Loading
            let faLoaded = false;
            let faSymbols = [];
            let faCurrentIndex = 0;
            const faChunkSize = 10;

            function loadFundamentalAnalysis() {
                if (faLoaded) return;
                faLoaded = true;
                
                // Plop the shell directly to bypass Script Execution blocks from innerHTML
                document.getElementById('fa-container').innerHTML = `
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" id="fa-table">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Symbol</th>
                                <th>Price</th>
                                <th>Market Cap</th>
                                <th>P/E (TTM)</th>
                                <th>ROCE/ROA</th>
                                <th>ROE</th>
                                <th>Yield</th>
                                <th>P/B</th>
                                <th>Category</th>
                                <th class="pe-4">Analysis</th>
                            </tr>
                        </thead>
                        <tbody id="fa-tbody">
                        </tbody>
                    </table>
                    <div id="fa-chunk-loading" class="text-center py-4 bg-light rounded-bottom-4 border-top">
                        <div class="spinner-border text-success spinner-border-sm me-2" role="status"></div>
                        <span class="text-success fw-bold" id="fa-progress-text">Connecting to Yahoo Finance API...</span>
                    </div>
                </div>`;

                fetch('@Url.Action("GetFundamentalSymbols", "Investments")')
                    .then(r => r.json())
                    .then(symbols => {
                        faSymbols = symbols;
                        faCurrentIndex = 0;
                        if (faSymbols.length === 0) {
                            document.getElementById('fa-chunk-loading').style.display = 'none';
                            document.getElementById('fa-tbody').innerHTML = '<tr><td colspan="10" class="text-center text-muted py-5"><i class="bi bi-info-circle me-2"></i>No symbols found for fundamental analysis.</td></tr>';
                            return;
                        }
                        document.getElementById('fa-progress-text').innerText = `Preparing to analyze 0 of ${faSymbols.length} records...`;
                        loadNextFaChunk();
                    })
                    .catch(e => {
                        document.getElementById('fa-container').innerHTML = '<div class="p-5 text-center text-danger">Failed to initialize fundamental analysis. Backend disconnected.</div>';
                    });
            }

            function loadNextFaChunk() {
                if (faCurrentIndex >= faSymbols.length) {
                    document.getElementById('fa-chunk-loading').style.display = 'none';
                    return;
                }

                const chunk = faSymbols.slice(faCurrentIndex, faCurrentIndex + faChunkSize);
                document.getElementById('fa-progress-text').innerText = `Analyzing batch: ${Math.min(faCurrentIndex + faChunkSize, faSymbols.length)} of ${faSymbols.length} records...`;

                fetch('@Url.Action("GetFundamentalAnalysisChunk", "Investments")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(chunk)
                })
                .then(r => {
                    if (!r.ok) throw new Error('HTTP Status ' + r.status);
                    return r.text();
                })
                .then(html => {
                    const tbody = document.getElementById('fa-tbody');
                    if (html.trim() !== '') {
                        tbody.insertAdjacentHTML('beforeend', html);
                    }
                    faCurrentIndex += faChunkSize;
                    setTimeout(loadNextFaChunk, 800);
                })
                .catch(e => {
                    console.error('Error loading fundamental chunk:', e);
                    const tbody = document.getElementById('fa-tbody');
                    tbody.insertAdjacentHTML('beforeend', `<tr><td colspan="10" class="text-center text-danger py-2 bg-danger-subtle fw-bold border-bottom">Error loading batch starting at index ${faCurrentIndex}. Moving to next batch.</td></tr>`);
                    faCurrentIndex += faChunkSize;
                    setTimeout(loadNextFaChunk, 2000); // Wait longer if it failed
                });
            }

            // Load TA or FA if it's the active tab initially
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('activeTab') === 'Technical Analysis' || document.getElementById('ta-tab').classList.contains('active')) {
                loadTechnicalAnalysis();
            }
            if (urlParams.get('activeTab') === 'Fundamental Analysis' || document.getElementById('fa-tab').classList.contains('active')) {
                loadFundamentalAnalysis();
            }

            // Or load it when the tab is shown
            document.getElementById('ta-tab').addEventListener('shown.bs.tab', function () {
                loadTechnicalAnalysis();
            });
            document.getElementById('fa-tab').addEventListener('shown.bs.tab', function () {
                loadFundamentalAnalysis();
            });
        });

        function updateSortTab(tabName) {
            const url = new URL(window.location);
            url.searchParams.set('activeTab', tabName);
            window.history.replaceState({}, '', url);

            // Toggle action buttons visibility
            const stocksActions = document.getElementById('stocks-actions');
            const mfsActions = document.getElementById('mfs-actions');

            if (stocksActions) stocksActions.style.setProperty('display', tabName === 'Stocks' ? 'flex' : 'none', 'important');
            if (mfsActions) mfsActions.style.setProperty('display', tabName === 'Mutual Funds' ? 'flex' : 'none', 'important');
        }
    </script>
}

<style>
    .custom-pills .nav-link { color: #6c757d; border: 1px solid transparent; }
    .custom-pills .nav-link.active { background-color: var(--bs-primary); color: white; }
    .custom-pills .nav-link:hover:not(.active) { background-color: #f8f9fa; }
</style>
