            function refreshCategoryDropdowns() {
                $.get('@Url.Action("GetGroupedCategoriesJson", "QuickEntry")', function (data) {
                    if (data.success) {
                        const newOptionsHtml = data.categories.map(c => {
                            if (c.group) {
                                // Since flat list is returned, we need to group them.
                                // It's easier to process them on the client side.
                                return null;
                            }
                        });
                        
                        // Let's build the HTML string for <optgroup>s and <option>s
                        let grouped = {};
                        data.categories.forEach(c => {
                            let g = c.group || "Main Categories";
                            if(!grouped[g]) grouped[g] = [];
                            grouped[g].push(c);
                        });

                        let html = '<option value="">-- Select --</option>';
                        for (let g in grouped) {
                            html += `<optgroup label="${g}">`;
                            grouped[g].forEach(c => {
                                html += `<option value="${c.value}">${c.text}</option>`;
                            });
                            html += `</optgroup>`;
                        }

                        // Save current selections
                        let currentCat = $('#CategoryId').val();
                        let currentEditCat = $('#editCategoryId').val();
                        let currentFilterCat = $('#filterCategory').val();

                        // Update dropdowns
                        $('#CategoryId').html(html);
                        $('#editCategoryId').html(html);
                        $('#filterCategory').html('<option value="">All Categories</option>' + html.replace('<option value="">-- Select --</option>', ''));

                        // Restore selections
                        if (currentCat) $('#CategoryId').val(currentCat);
                        if (currentEditCat) $('#editCategoryId').val(currentEditCat);
                        if (currentFilterCat) $('#filterCategory').val(currentFilterCat);
                    }
                });
            }
            
            // Edit functionality
            const editModal = new bootstrap.Modal(document.getElementById('editTransactionModal'));
            
            $(document).on('click', '.edit-btn', function(e) {
                e.preventDefault();
                e.stopPropagation();
                e.stopImmediatePropagation();

                const id = $(this).data('id');
                const $row = $(this).closest('tr');
                const isSalary = $row.find('.salary-masked').length > 0 || $row.find('[data-salary="true"]').length > 0;

                if (isSalary) {
                    currentSalaryId = id;
                    currentSalaryCell = $row.find('[data-salary="true"]');
