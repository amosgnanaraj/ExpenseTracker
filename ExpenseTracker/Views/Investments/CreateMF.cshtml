@model ExpenseTracker.Models.MutualFund
@{
    ViewData["Title"] = "Add Mutual Fund";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-6 mx-auto">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-info text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-pie-chart-fill me-2"></i>New Mutual Fund Investment</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="CreateMF">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label asp-for="Name" class="form-label fw-bold small text-uppercase">Fund Name</label>
                                <input asp-for="Name" class="form-control border-info shadow-sm rounded-3" placeholder="e.g. HDFC Index Fund" required />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Symbol" class="form-label fw-bold small text-uppercase">Fund Symbol / Code</label>
                                <input asp-for="Symbol" class="form-control border-info shadow-sm rounded-3" placeholder="Optional" />
                                <span asp-validation-for="Symbol" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="FolioNumber" class="form-label fw-bold small text-uppercase">Folio Number</label>
                                <input asp-for="FolioNumber" class="form-control border-info shadow-sm rounded-3" placeholder="Optional" />
                                <span asp-validation-for="FolioNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Units" class="form-label fw-bold small text-uppercase">Units / Quantity</label>
                                <input asp-for="Units" class="form-control border-info shadow-sm rounded-3" type="number" step="0.0001" required />
                                <span asp-validation-for="Units" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="AvgNAV" class="form-label fw-bold small text-uppercase">Avg. NAV (Buy Price)</label>
                                <input asp-for="AvgNAV" class="form-control border-info shadow-sm rounded-3" type="number" step="0.0001" required />
                                <span asp-validation-for="AvgNAV" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CurrentNAV" class="form-label fw-bold small text-uppercase">Current NAV</label>
                                <input asp-for="CurrentNAV" class="form-control border-info shadow-sm rounded-3" type="number" step="0.0001" required />
                                <span asp-validation-for="CurrentNAV" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PurchaseDate" class="form-label fw-bold small text-uppercase">Purchase Date</label>
                                <input asp-for="PurchaseDate" class="form-control border-info shadow-sm rounded-3" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="PurchaseDate" class="text-danger small"></span>
                            </div>
                            <div class="col-12 mt-4 text-end">
                                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 me-2">Cancel</a>
                                <button type="submit" class="btn btn-info text-white rounded-pill px-5 shadow">Save Fund</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
