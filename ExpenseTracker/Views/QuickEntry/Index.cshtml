                    id: id
                }, function (response) {
                    if (response.success) {
                        $('#categoryAlertPlaceholder').html(`<div class="alert alert-success py-2 px-3 small mb-3"><i class="bi bi-check-circle-fill me-2"></i>${response.message}</div>`);
