            // ── Category Management ──────────────────────────
            const manageCategoriesModalEl = document.getElementById('manageCategoriesModal');
            let categoriesData = [];

            manageCategoriesModalEl.addEventListener('show.bs.modal', function () {
                loadCategoriesList();
            });

            manageCategoriesModalEl.addEventListener('hidden.bs.modal', function () {
                resetCategoryForm();
                $('#categoryAlertPlaceholder').empty();
                refreshCategoryDropdowns();
            });

            function loadCategoriesList() {
                $.get('@Url.Action("GetCategoriesList", "QuickEntry")', function (data) {
                    if (data.success) {
                        categoriesData = data.categories;
                        renderCategoriesTable();
                        updateParentCategoryDropdown();
                    }
                });
            }

            function renderCategoriesTable() {
                const tbody = $('#categoriesListBody');
                tbody.empty();
                if (categoriesData.length === 0) {
                    tbody.html('<tr><td colspan="3" class="text-center text-muted">No categories found.</td></tr>');
                    return;
                }
                
                categoriesData.forEach(c => {
                    const parentName = c.parentCategoryName ? `<span class="badge bg-light text-secondary border">${c.parentCategoryName}</span>` : '<span class="text-muted small">-</span>';
                    tbody.append(`
                        <tr class="border-bottom">
                            <td class="fw-medium">${c.name}</td>
                            <td>${parentName}</td>
                            <td class="text-end">
                                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill edit-category-btn p-1 me-1" data-id="${c.id}" data-name="${c.name}" data-parent="${c.parentCategoryId || ''}" title="Edit">
                                    <i class="bi bi-pencil" style="font-size: 0.75rem;"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-danger rounded-pill delete-category-btn p-1" data-id="${c.id}" title="Delete">
                                    <i class="bi bi-trash" style="font-size: 0.75rem;"></i>
                                </button>
                            </td>
                        </tr>
