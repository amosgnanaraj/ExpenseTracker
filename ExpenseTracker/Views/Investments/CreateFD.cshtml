@model ExpenseTracker.Models.FixedDeposit
@{
    ViewData["Title"] = "Add Fixed Deposit";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-6 mx-auto">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-safe2-fill me-2"></i>New Fixed Deposit</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="CreateFD">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label asp-for="BankName" class="form-label fw-bold small text-uppercase">Bank Name</label>
                                <input asp-for="BankName" class="form-control border-success shadow-sm rounded-3" placeholder="e.g. HDFC Bank" list="bankList" required />
                                <datalist id="bankList">
                                    @if (ViewBag.Banks != null)
                                    {
                                        foreach (var bank in (List<string>)ViewBag.Banks)
                                        {
                                            <option value="@bank"></option>
                                        }
                                    }
                                </datalist>
                                <span asp-validation-for="BankName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-12">
                                <label asp-for="CertificateNumber" class="form-label fw-bold small text-uppercase">Certificate / FD Number</label>
                                <input asp-for="CertificateNumber" class="form-control border-success shadow-sm rounded-3" placeholder="Optional" />
                                <span asp-validation-for="CertificateNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-md-12">
                                <label asp-for="PrincipalAmount" class="form-label fw-bold small text-uppercase">Principal Amount</label>
                                <input asp-for="PrincipalAmount" class="form-control border-success shadow-sm rounded-3" type="number" step="0.01" required />
                                <span asp-validation-for="PrincipalAmount" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="InterestRate" class="form-label fw-bold small text-uppercase">Interest Rate (%)</label>
                                <input asp-for="InterestRate" class="form-control border-success shadow-sm rounded-3" type="number" step="0.01" required />
                                <span asp-validation-for="InterestRate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="MaturityDate" class="form-label fw-bold small text-uppercase">Maturity Date</label>
                                <input asp-for="MaturityDate" class="form-control border-success shadow-sm rounded-3" type="date" required />
                                <span asp-validation-for="MaturityDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PayoutType" class="form-label fw-bold small text-uppercase">Interest Payout</label>
                                <select asp-for="PayoutType" class="form-select border-success shadow-sm rounded-3" asp-items="Html.GetEnumSelectList<ExpenseTracker.Models.InterestPayoutType>()"></select>
                                <span asp-validation-for="PayoutType" class="text-danger small"></span>
                            </div>
                            <div class="col-md-12">
                                <label asp-for="PurchaseDate" class="form-label fw-bold small text-uppercase">Deposit Date</label>
                                <input asp-for="PurchaseDate" class="form-control border-success shadow-sm rounded-3" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="PurchaseDate" class="text-danger small"></span>
                            </div>
                            <div class="col-12 mt-4 text-end">
                                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 me-2">Cancel</a>
                                <button type="submit" class="btn btn-success text-white rounded-pill px-5 shadow">Save FD</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
