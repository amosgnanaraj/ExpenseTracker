            $('#editTransactionForm').on('submit', function(e) {
                e.preventDefault();
                const id = $('#editId').val();
                const $form = $(this);
                const $btn = $('#editSubmitBtn');
                const $spinner = $('#editSubmitSpinner');
                const $btnText = $('#editSubmitText');
                
                $btn.prop('disabled', true);
                $spinner.removeClass('d-none');
                $btnText.addClass('d-none');
                
                $.ajax({
                    url: '@Url.Action("UpdateTransaction", "QuickEntry")/' + id,
                    type: 'POST',
                    data: $form.serialize(),
                    success: function(response) {
                        if (response.success) {
                            const t = response.transaction;
                            let typeBadgeClass = 'bg-secondary';
                            let amountClass = 'text-danger';
                            let amountPrefix = '-';

                            if (t.type === 'Credit') {
                                typeBadgeClass = 'bg-success';
                                amountClass = 'text-success';
                                amountPrefix = '+';
                            } else if (t.type === 'Debit') {
                                typeBadgeClass = 'bg-danger';
                            } else if (t.type === 'Transfer') {
                                typeBadgeClass = 'bg-info text-dark';
                            }

                            const transferInfo = t.transferToName ? ' → ' + t.transferToName : '';
                            
                            const updatedRow = renderRow(t);
