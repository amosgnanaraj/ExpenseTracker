<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ExpenseTracker</title>
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', savedTheme);
        })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ExpenseTracker.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">ExpenseTracker</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-semibold" asp-area="" asp-controller="AccountSources" asp-action="Index">Accounts</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-semibold" asp-area="" asp-controller="Investments" asp-action="Index">Investments</a>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-danger fw-bold" asp-area="" asp-controller="Account" asp-action="AddUser"><i class="bi bi-person-fill-add me-1"></i>Add User</a>
                                </li>
                            }
                        }
                    </ul>
                    
                    <div class="d-flex align-items-center me-2">
                        <button id="themeToggleBtn" class="btn btn-link text-secondary p-2 rounded-circle" style="text-decoration: none; border: none; box-shadow: none;" aria-label="Toggle theme">
                            <i class="bi bi-moon-stars-fill fs-5" id="themeToggleIcon"></i>
                        </button>
                    </div>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="d-flex align-items-center me-3">
                            <span class="text-muted small me-3"><i class="bi bi-person-circle me-1"></i> @User.Identity.Name</span>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-secondary btn-sm rounded-pill fw-bold">Logout</button>
                            </form>
                        </div>
                        <div class="d-flex">
                            <a class="btn btn-primary rounded-pill fw-bold shadow-sm" asp-area="" asp-controller="QuickEntry" asp-action="Index">
                                <i class="bi bi-plus-circle-fill me-1"></i> Quick Entry
                            </a>
                        </div>
                    }
                    else
                    {
                         <div class="d-flex">
                            <a class="btn btn-primary rounded-pill fw-bold shadow-sm" asp-area="" asp-controller="Account" asp-action="Login">
                                Login
                            </a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ExpenseTracker - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
