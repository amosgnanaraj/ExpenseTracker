            });

            loadPage(1); // initial page load

            // ── PIN Authentication ─────────────────────────
            const pinModal = new bootstrap.Modal(document.getElementById('pinAuthModal'));
            let currentSalaryId = null;
            let currentSalaryCell = null;
            let isEditing = false;

            $(document).on('click', '.salary-masked', function(e) {
                e.preventDefault();
                e.stopPropagation();
                e.stopImmediatePropagation();
                currentSalaryId = $(this).data('id');
                currentSalaryCell = $(this);
                isEditing = false;
                $('#pinInput').val('');
                $('#pinError').addClass('d-none');
                pinModal.show();
                setTimeout(() => $('#pinInput').focus(), 500);
                return false;
            });

            $('#pinSubmitBtn').on('click', function() {
                const pin = $('#pinInput').val();
                if (!pin) return;

                $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');
                
                $.get('@Url.Action("GetSalaryAmount", "QuickEntry")', { id: currentSalaryId, pin: pin }, function(response) {
                    if (response.success) {
                        if (isEditing) {
                            pinModal.hide();
                            openEditModal(currentSalaryId, pin);
                        } else {
                            const prefix = currentSalaryCell.text().startsWith('+') ? '+' : (currentSalaryCell.text().startsWith('-') ? '-' : '');
                            currentSalaryCell.text(prefix + response.amount);
                            currentSalaryCell.removeClass('salary-masked clickable').removeAttr('data-salary');
                            pinModal.hide();
                        }
                    } else {
                        $('#pinError').text(response.message).removeClass('d-none');
                        $('#pinInput').val('').focus();
                    }
                }).always(function() {
                    $('#pinSubmitBtn').prop('disabled', false).text('Verify');
                });
            });

            $('#pinInput').on('keypress', function(e) {
                if (e.which == 13) $('#pinSubmitBtn').click();
            });

            // ── Inline Category Edit ─────────────────────────
            $(document).on('click', '.category-display.clickable', function(e) {
                e.preventDefault();
                e.stopPropagation();
                const $cell = $(this).closest('.category-cell');
                const $display = $(this);
                const $edit = $cell.find('.category-edit');
                const $select = $edit.find('select');
                const categoryId = $cell.data('category-id');

                // populate options from the main category dropdown
                $select.html($('#CategoryId').html());
                $select.val(categoryId);
                $select.data('original', categoryId);

                $display.addClass('d-none');
                $edit.removeClass('d-none');
                $select.focus();
            });

            $(document).on('change', '.inline-category-select', function() {
                const $select = $(this);
                const $cell = $select.closest('.category-cell');
                const $display = $cell.find('.category-display');
                const $edit = $cell.find('.category-edit');
                const id = $cell.data('id');
                const newCategoryId = $select.val();
                const originalCategoryId = $select.data('original');

                if (newCategoryId === originalCategoryId || !newCategoryId) {
                    $edit.addClass('d-none');
                    $display.removeClass('d-none');
                    return;
                }

                $select.prop('disabled', true);
                
                $.post('@Url.Action("UpdateTransactionCategory", "QuickEntry")', {
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').first().val(),
                    id: id,
                    categoryId: newCategoryId
                }, function(response) {
                    if (response.success) {
                        $cell.data('category-id', newCategoryId);
                        $display.find('.category-name-span').text(response.categoryName);
                        $edit.addClass('d-none');
                        $display.removeClass('d-none');
                        
                        // flash the cell green to indicate success
                        $cell.css('background-color', '#e8f5e9');
                        setTimeout(() => $cell.css('background-color', ''), 1000);
                    } else {
                        alert(response.message);
                        $select.val(originalCategoryId);
                        $edit.addClass('d-none');
                        $display.removeClass('d-none');
                    }
                }).fail(function() {
                    alert("An error occurred updating the category.");
                    $select.val(originalCategoryId);
                    $edit.addClass('d-none');
                    $display.removeClass('d-none');
                }).always(function() {
                    $select.prop('disabled', false);
                });
            });

            $(document).on('blur', '.inline-category-select', function() {
                const $select = $(this);
                if ($select.is(':disabled')) return; // let the ajax call handle it
                const $cell = $select.closest('.category-cell');
                $cell.find('.category-edit').addClass('d-none');
                $cell.find('.category-display').removeClass('d-none');
            });
        });
    </script>
    <style>
        .salary-masked {
            background-color: #f8f9fa;
            border-radius: 4px;
            cursor: pointer;
            transition: background-color 0.2s;
        }
        .salary-masked:hover {
            background-color: #e9ecef;
        }
        .clickable {
            cursor: pointer;
        }
    </style>
}

<!-- PIN Auth Modal -->
<div class="modal fade" id="pinAuthModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-body p-4 text-center">
                <i class="bi bi-shield-lock-fill text-primary display-4 mb-3"></i>
                <h5 class="fw-bold mb-3">Enter PIN</h5>
                <p class="small text-muted mb-4">This transaction is protected. Please enter your PIN to view the amount.</p>
                <div id="pinError" class="alert alert-danger small py-2 d-none mb-3"></div>
                <div style="position: absolute; width: 1px; height: 1px; overflow: hidden; opacity: 0; pointer-events: none;" aria-hidden="true">
                    <input type="text" name="dummy_username" autocomplete="username" tabindex="-1">
                </div>
                <input type="password" id="pinInput" class="form-control form-control-lg text-center mb-4 rounded-3 border-2" maxlength="4" placeholder="••••" autocomplete="new-password" />
                <div class="d-grid gap-2">
                    <button type="button" id="pinSubmitBtn" class="btn btn-primary rounded-pill fw-bold">Verify</button>
                    <button type="button" class="btn btn-link btn-sm text-secondary text-decoration-none" data-bs-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>
</div>
