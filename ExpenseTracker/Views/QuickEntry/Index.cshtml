@model ExpenseTracker.Models.QuickEntryViewModel

@{
    ViewData["Title"] = "Quick Entry";
    var currentYear = DateTime.Now.Year;
}

<div class="container-fluid mt-4">
    <!-- Hidden fields to absorb aggressive browser autofill -->
    <div style="position: absolute; width: 1px; height: 1px; overflow: hidden; opacity: 0; pointer-events: none;" aria-hidden="true">
        <input type="text" id="fakeUsername" name="fakeUsername" autocomplete="username" tabindex="-1">
        <input type="password" id="fakePassword" name="fakePassword" autocomplete="current-password" tabindex="-1">
    </div>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold"><i class="bi bi-lightning-charge-fill text-warning me-2"></i>Quick Entry</h3>
        <button class="btn btn-sm btn-outline-success rounded-pill fw-bold" type="button" data-bs-toggle="modal" data-bs-target="#importStatementModal">
            <i class="bi bi-file-earmark-excel me-1"></i>Import Bank Statement
        </button>
    </div>

    <div id="alertPlaceholder"></div>

    <!-- Inline Form Card -->
    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body p-3">
            <form id="quickEntryForm" method="post" asp-action="SubmitTransaction">
                @Html.AntiForgeryToken()
                <div class="row g-2 align-items-end">
                    
                    <div class="col-md-2">
                        <label asp-for="Date" class="form-label small fw-bold text-secondary mb-1"></label>
                        <input asp-for="Date" class="form-control form-control-sm bg-light" type="date" />
                        <span asp-validation-for="Date" class="text-danger small"></span>
                    </div>

                    <div class="col-md-1">
                        <label asp-for="Type" class="form-label small fw-bold text-secondary mb-1">Type</label>
                        <select asp-for="Type" id="transactionType" class="form-select form-select-sm bg-light"
                                asp-items="Html.GetEnumSelectList<ExpenseTracker.Models.TransactionType>()">
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label asp-for="AccountSourceId" class="form-label small fw-bold text-secondary mb-1">Account</label>
                        <select asp-for="AccountSourceId" asp-items="Model.AccountSources" class="form-select form-select-sm bg-light">
                            <option value="">-- Select --</option>
                        </select>
                        <span asp-validation-for="AccountSourceId" class="text-danger small"></span>
                    </div>

                    <div id="transferToSection" class="col-md-2" style="display:none;">
                        <label asp-for="TransferToAccountSourceId" class="form-label small fw-bold text-secondary mb-1">Transfer To</label>
                        <select asp-for="TransferToAccountSourceId" asp-items="Model.AccountSources" class="form-select form-select-sm bg-light">
                            <option value="">-- Select --</option>
                        </select>
                        <span asp-validation-for="TransferToAccountSourceId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-2">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label asp-for="CategoryId" class="form-label small fw-bold text-secondary mb-0">Category</label>
                            <button type="button" class="btn btn-sm btn-link p-0 text-decoration-none" data-bs-toggle="modal" data-bs-target="#manageCategoriesModal" title="Manage Categories">
                                <i class="bi bi-gear text-primary"></i>
                            </button>
                        </div>
                        <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select form-select-sm bg-light">
                            <option value="">-- Select --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div id="salarySection" class="col-md-2" style="display:none;">
                        <label class="form-label small fw-bold text-secondary mb-1">Salary Period</label>
                        <div class="d-flex gap-1">
                            <select asp-for="SalaryMonth" id="salaryMonth" class="form-select form-select-sm bg-light">
                                <option value="">Month</option>
                                <option value="1">Jan</option>
                                <option value="2">Feb</option>
                                <option value="3">Mar</option>
                                <option value="4">Apr</option>
                                <option value="5">May</option>
                                <option value="6">Jun</option>
                                <option value="7">Jul</option>
                                <option value="8">Aug</option>
                                <option value="9">Sep</option>
                                <option value="10">Oct</option>
                                <option value="11">Nov</option>
                                <option value="12">Dec</option>
                            </select>
                            <select asp-for="SalaryYear" id="salaryYear" class="form-select form-select-sm bg-light">
                                <option value="">Year</option>
                                @for (int y = currentYear - 2; y <= currentYear + 2; y++)
                                {
                                    <option value="@y">@y</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="col-md-1">
                        <label asp-for="Amount" class="form-label small fw-bold text-secondary mb-1"></label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light text-muted border-end-0">₹</span>
                            <input asp-for="Amount" class="form-control bg-light border-start-0 ps-0" type="number" step="0.01" min="0.01" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Amount" class="text-danger small"></span>
                    </div>

                    <div class="col-md-2">
                        <label asp-for="Description" class="form-label small fw-bold text-secondary mb-1">Description (Opt)</label>
                        <input asp-for="Description" class="form-control form-control-sm bg-light" placeholder="What was this for?" autocomplete="off" />
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="col-md d-grid">
                        <button type="submit" id="submitBtn" class="btn btn-primary btn-sm rounded-3 fw-bold shadow-sm">
                            <span class="spinner-border spinner-border-sm d-none" id="submitSpinner" role="status" aria-hidden="true"></span>
                            <span id="submitText">Save</span>
                        </button>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <!-- History DataGrid Card -->
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2 text-primary"></i>Recent Transactions</h5>
            <button class="btn btn-sm btn-outline-primary rounded-pill fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse" aria-expanded="false" aria-controls="filterCollapse">
                <i class="bi bi-filter me-1"></i>Filter
            </button>
        </div>
        <div class="card-body p-0">
            <!-- Filter Bar -->
            <div class="collapse" id="filterCollapse">
                <div class="p-3 border-bottom bg-light bg-opacity-50 shadow-sm">
                    <div class="row g-2 align-items-center">
                        <div class="col-md-3 col-lg-4">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text border-end-0 bg-white shadow-none"><i class="bi bi-search text-muted"></i></span>
                                <input type="search" id="filterSearch" class="form-control border-start-0 ps-0 shadow-none" placeholder="Search description..." autocomplete="off" readonly onfocus="this.removeAttribute('readonly');">
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border-end-0 text-muted small">From</span>
                                <input type="date" id="filterDateFrom" class="form-control border-start-0 ps-1 shadow-none" autocomplete="off">
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border-end-0 text-muted small">To</span>
                                <input type="date" id="filterDateTo" class="form-control border-start-0 ps-1 shadow-none" autocomplete="off">
                            </div>
                        </div>
                        <div class="col-md-2">
                            <select id="filterType" class="form-select form-select-sm shadow-none">
                                <option value="">All Types</option>
                                @foreach (var item in Html.GetEnumSelectList<ExpenseTracker.Models.TransactionType>())
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-1 col-lg-2 text-end">
                            <button id="clearFiltersBtn" class="btn btn-sm btn-outline-secondary rounded-pill fw-bold px-3">
                                <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
                            </button>
                        </div>
                    </div>
                    <div class="row g-2 align-items-center mt-2">
                        <div class="col-md-4">
                            <select id="filterCategory" class="form-select form-select-sm shadow-none" asp-items="Model.Categories">
                                <option value="">All Categories</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <select id="filterAccount" class="form-select form-select-sm shadow-none" asp-items="Model.AccountSources">
                                <option value="">All Accounts</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-borderless align-middle mb-0" id="transactionsTable">
                    <thead class="table-light text-muted small">
                        <tr>
                            <th class="ps-4">Date</th>
                            <th>Type</th>
                            <th>Account</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th class="text-end">Amount</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="transactionList">
                        @if (!Model.RecentTransactions.Any())
                        {
                            <tr id="emptyRow">
                                <td colspan="6" class="text-center py-4 text-muted">
                                    No recent transactions found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.RecentTransactions)
                            {
                                var typeBadge = item.Type switch
                                {
                                    ExpenseTracker.Models.TransactionType.Credit => "bg-success",
                                    ExpenseTracker.Models.TransactionType.Debit => "bg-danger",
                                    ExpenseTracker.Models.TransactionType.Transfer => "bg-info text-dark",
                                    _ => "bg-secondary"
                                };
                                var amountClass = item.Type == ExpenseTracker.Models.TransactionType.Credit ? "text-success" : "text-danger";
                                var amountPrefix = item.Type == ExpenseTracker.Models.TransactionType.Credit ? "+" : "-";
                                var transferInfo = item.Type == ExpenseTracker.Models.TransactionType.Transfer && item.TransferToAccountSource != null
                                    ? $" → {item.TransferToAccountSource.Name}" : "";
                                
                                bool isSalary = item.Category?.Name?.Contains("Salary", StringComparison.OrdinalIgnoreCase) ?? false;
                                var displayAmount = isSalary ? "*****" : item.Amount.ToString("C");
                                var salaryClass = isSalary ? "salary-masked clickable" : "";

                                <tr class="border-bottom">
                                    <td class="ps-4 text-muted small">@item.Date.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                    <td><span class="badge rounded-pill @typeBadge">@item.Type</span></td>
                                    <td>
                                        <span class="badge bg-light text-dark border">@item.AccountSource?.Name</span>
                                        @if (!string.IsNullOrEmpty(transferInfo))
                                        {
                                            <span class="text-muted small">@transferInfo</span>
                                        }
                                    </td>
                                    <td class="category-cell" data-id="@item.Id" data-category-id="@item.CategoryId">
                                        <div class="category-display clickable d-inline-flex align-items-center" title="Click to edit category">
                                            <span class="badge bg-light text-primary border category-name-span">@item.Category?.Name</span>
                                            @if (isSalary && item.SalaryMonth.HasValue && item.SalaryYear.HasValue)
                                            {
                                                var monthName = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(item.SalaryMonth.Value);
                                                <span class="badge bg-light text-muted border small ms-1 category-salary-span">@monthName @item.SalaryYear</span>
                                            }
                                            <i class="bi bi-pencil-square text-muted ms-1 small opacity-50"></i>
                                        </div>
                                        <div class="category-edit d-none">
                                            <select class="form-select form-select-sm inline-category-select">
                                                <option value="">Select...</option>
                                            </select>
                                        </div>
                                    </td>
                                    <td class="text-truncate" style="max-width: 250px;">@item.Description</td>
                                    <td class="text-end fw-bold font-monospace @amountClass @salaryClass" data-id="@item.Id" data-salary="@isSalary.ToString().ToLower()">@amountPrefix@displayAmount</td>
                                    <td class="text-end pe-4">
                                        <button class="btn btn-sm btn-outline-secondary rounded-pill edit-btn" data-id="@item.Id">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger rounded-pill delete-btn" data-id="@item.Id">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <!-- Pagination Bar -->
            <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top bg-white rounded-bottom-4" id="paginationBar">
                <span class="text-muted small" id="paginationInfo">Loading...</span>
                <nav>
                    <ul class="pagination pagination-sm mb-0" id="paginationControls">
                    </ul>
                </nav>
            </div>
        </div>
    </div>

<!-- Edit Transaction Modal -->
<div class="modal fade" id="editTransactionModal" tabindex="-1" aria-labelledby="editTransactionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="editTransactionModalLabel"><i class="bi bi-pencil-square text-primary me-2"></i>Edit Transaction</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editTransactionForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editId" />
                <div class="modal-body py-4">
                    <div id="editAlertPlaceholder"></div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-secondary mb-1">Date</label>
                            <input name="Date" id="editDate" class="form-control bg-light" type="date" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-secondary mb-1">Type</label>
                            <select name="Type" id="editType" class="form-select bg-light" required>
                                @foreach (var item in Html.GetEnumSelectList<ExpenseTracker.Models.TransactionType>())
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-secondary mb-1">Amount</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-muted border-end-0">₹</span>
                                <input name="Amount" id="editAmount" class="form-control bg-light border-start-0 ps-0" type="number" step="0.01" min="0.01" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary mb-1">Account</label>
                            <select name="AccountSourceId" id="editAccountSourceId" class="form-select bg-light" required>
                                <option value="">-- Select --</option>
                                @foreach (var item in Model.AccountSources)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 editTransferToSection" style="display:none;">
                            <label class="form-label small fw-bold text-secondary mb-1">Transfer To</label>
                            <select name="TransferToAccountSourceId" id="editTransferToAccountSourceId" class="form-select bg-light">
                                <option value="">-- Select --</option>
                                @foreach (var item in Model.AccountSources)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary mb-1">Category</label>
                            <select name="CategoryId" id="editCategoryId" class="form-select bg-light" required>
                                <option value="">-- Select --</option>
                                @foreach (var item in Model.Categories)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 editSalarySection" style="display:none;">
                            <label class="form-label small fw-bold text-secondary mb-1">Salary Month/Year</label>
                            <div class="d-flex gap-2">
                                <select name="SalaryMonth" id="editSalaryMonth" class="form-select bg-light">
                                    <option value="">Month</option>
                                    <option value="1">January</option>
                                    <option value="2">February</option>
                                    <option value="3">March</option>
                                    <option value="4">April</option>
                                    <option value="5">May</option>
                                    <option value="6">June</option>
                                    <option value="7">July</option>
                                    <option value="8">August</option>
                                    <option value="9">September</option>
                                    <option value="10">October</option>
                                    <option value="11">November</option>
                                    <option value="12">December</option>
                                </select>
                                <select name="SalaryYear" id="editSalaryYear" class="form-select bg-light">
                                    <option value="">Year</option>
                                    @for (int y = currentYear - 2; y <= currentYear + 2; y++)
                                    {
                                        <option value="@y">@y</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label small fw-bold text-secondary mb-1">Description</label>
                            <input name="Description" id="editDescription" class="form-control bg-light" placeholder="What was this for?" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="editSubmitBtn" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                        <span class="spinner-border spinner-border-sm d-none" id="editSubmitSpinner" role="status" aria-hidden="true"></span>
                        <span id="editSubmitText">Update Transaction</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

</div>

<!-- Import Statement Modal -->
<div class="modal fade" id="importStatementModal" tabindex="-1" aria-labelledby="importStatementModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="importStatementModalLabel"><i class="bi bi-file-earmark-excel text-success me-2"></i>Import Bank Statement</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="importStatementForm" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body py-4">
                    <div id="importAlertPlaceholder"></div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary mb-1">Select Account</label>
                        <select name="accountId" class="form-select bg-light" required>
                            @foreach (var account in Model.AccountSources)
                            {
                                // Default to SBI if possible (Account ID 2)
                                <option value="@account.Value" selected="@(account.Value == "2")">@account.Text</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary mb-1">Excel File</label>
                        <input type="file" name="statementFile" class="form-control bg-light" accept=".xls,.xlsx" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary mb-1">Password (if encrypted)</label>
                        <input type="password" name="password" class="form-control bg-light" placeholder="Leave blank if no password" />
                    </div>
                    <div class="small text-muted">
                        <i class="bi bi-info-circle me-1"></i>Supports SBI and Axis Bank Excel statements. Ensure the correct account is selected.
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="importSubmitBtn" class="btn btn-success rounded-pill px-4 fw-bold shadow-sm">
                        <span class="spinner-border spinner-border-sm d-none" id="importSubmitSpinner" role="status" aria-hidden="true"></span>
                        <span id="importSubmitText">Start Import</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Manage Categories Modal -->
<div class="modal fade" id="manageCategoriesModal" tabindex="-1" aria-labelledby="manageCategoriesModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="manageCategoriesModalLabel"><i class="bi bi-tags text-primary me-2"></i>Manage Categories</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <div id="categoryAlertPlaceholder"></div>
                
                <!-- Add/Edit Category Form -->
                <div class="card bg-light border-0 mb-4">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3" id="categoryFormTitle">Add New Category</h6>
                        <form id="categoryForm">
                            <input type="hidden" id="categoryId" name="id" />
                            <div class="row g-2 align-items-end">
                                <div class="col-md-5">
                                    <label class="form-label small fw-bold text-secondary mb-1">Name</label>
                                    <input type="text" id="categoryName" name="name" class="form-control form-control-sm" required autocomplete="off" />
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label small fw-bold text-secondary mb-1">Parent Category (Optional)</label>
                                    <select id="parentCategoryId" name="parentCategoryId" class="form-select form-select-sm">
                                        <option value="">-- None (Top Level) --</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <button type="submit" class="btn btn-primary btn-sm w-100 fw-bold" id="categorySubmitBtn">Save</button>
                                </div>
                            </div>
                            <div class="mt-2 text-end" id="categoryCancelBtnContainer" style="display:none;">
                                <button type="button" class="btn btn-sm btn-link text-secondary text-decoration-none" id="cancelCategoryEditBtn">Cancel Edit</button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Categories List -->
                <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                    <table class="table table-hover table-sm align-middle mb-0" id="categoriesTable">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>Name</th>
                                <th>Parent</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="categoriesListBody">
                            <tr><td colspan="3" class="text-center text-muted">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            // Toggle Transfer To field visibility
            function toggleTransferField() {
                var selectedType = $('#transactionType').val();
                if (selectedType === 'Transfer' || selectedType === '2') {
                    $('#transferToSection').show();
                } else {
                    $('#transferToSection').hide();
                    $('#TransferToAccountSourceId').val('');
                }
            }

            $('#transactionType').on('change', toggleTransferField);
            toggleTransferField(); // Initial state

            // Toggle Salary fields visibility
            function toggleSalaryFields() {
                var selectedCategoryText = $('#CategoryId option:selected').text();
                if (selectedCategoryText.indexOf('Salary') > -1) {
                    $('#salarySection').show();
                } else {
                    $('#salarySection').hide();
                    $('#salaryMonth').val('');
                    $('#salaryYear').val('');
