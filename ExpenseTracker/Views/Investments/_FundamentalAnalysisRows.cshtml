@model List<ExpenseTracker.Models.FundamentalAnalysisResult>

@foreach (var item in Model)
{
    <tr>
        <td class="ps-4 fw-bold">
            <div class="d-flex align-items-center">
                <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                    <i class="bi bi-bank2"></i>
                </div>
                @item.Symbol
            </div>
        </td>
        <td class="fw-semibold">@(item.CurrentPrice?.ToString("N2") ?? "-")</td>
        <td>@(item.MarketCap.HasValue ? (item.MarketCap.Value / 1000000000).ToString("N2") + "B" : "-")</td>
        <td>@(item.TrailingPE?.ToString("N2") ?? "-")</td>
        <td>@(item.ROCE.HasValue ? (item.ROCE.Value * 100).ToString("N2") + "%" : "-")</td>
        <td>@(item.ReturnOnEquity.HasValue ? (item.ReturnOnEquity.Value * 100).ToString("N2") + "%" : "-")</td>
        <td>@(item.DividendYield.HasValue ? (item.DividendYield.Value * 100).ToString("N2") + "%" : "-")</td>
        <td>@(item.PriceToBook?.ToString("N2") ?? "-")</td>
        <td>
            @{
                var badgeClass = item.Category switch {
                    "Value" => "bg-primary",
                    "Growth" => "bg-info text-dark",
                    "Income" => "bg-success",
                    "Overvalued" => "bg-danger",
                    "Error" => "bg-secondary border border-secondary text-white",
                    _ => "bg-secondary"
                };
            }
            <span class="badge @badgeClass rounded-pill px-3 py-2 shadow-sm">@item.Category</span>
        </td>
        <td class="text-muted small pe-4" style="max-width: 250px;">
            @item.Reason
        </td>
    </tr>
}
