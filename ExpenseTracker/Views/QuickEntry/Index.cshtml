                        $('#categoryAlertPlaceholder').html(`<div class="alert alert-danger py-2 px-3 small mb-3"><i class="bi bi-exclamation-triangle-fill me-2"></i>${response.message}</div>`);
                        btn.prop('disabled', false);
                    }
                }).fail(function () {
                    $('#categoryAlertPlaceholder').html(`<div class="alert alert-danger py-2 px-3 small mb-3">An error occurred.</div>`);
