                        $('#editTransferToAccountSourceId').val(data.transferToAccountSourceId);
                    } else {
                        $('.editTransferToSection').hide();
                        $('#editTransferToAccountSourceId').val('');
                    }
                    
                    $('#editAlertPlaceholder').empty();
                    editModal.show();
                }).fail(function() {
                    alert('Could not fetch transaction details.');
