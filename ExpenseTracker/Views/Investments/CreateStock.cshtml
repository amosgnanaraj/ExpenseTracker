@model ExpenseTracker.Models.Stock
@{
    ViewData["Title"] = "Add Stock";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-6 mx-auto">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-graph-up-arrow me-2"></i>New Stock Investment</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="CreateStock">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label asp-for="Name" class="form-label fw-bold small text-uppercase">Stock Name</label>
                                <input asp-for="Name" class="form-control border-primary shadow-sm rounded-3" placeholder="e.g. Reliance Industries" required />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-12">
                                <label asp-for="Symbol" class="form-label fw-bold small text-uppercase">Symbol</label>
                                <input asp-for="Symbol" class="form-control border-primary shadow-sm rounded-3" placeholder="e.g. RELIANCE" required />
                                <span asp-validation-for="Symbol" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Quantity" class="form-label fw-bold small text-uppercase">Quantity</label>
                                <input asp-for="Quantity" class="form-control border-primary shadow-sm rounded-3" type="number" step="0.0001" required />
                                <span asp-validation-for="Quantity" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="BuyPrice" class="form-label fw-bold small text-uppercase">Avg. Buy Price</label>
                                <input asp-for="BuyPrice" class="form-control border-primary shadow-sm rounded-3" type="number" step="0.01" required />
                                <span asp-validation-for="BuyPrice" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CurrentPrice" class="form-label fw-bold small text-uppercase">Current Market Price</label>
                                <input asp-for="CurrentPrice" class="form-control border-primary shadow-sm rounded-3" type="number" step="0.01" required />
                                <span asp-validation-for="CurrentPrice" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PurchaseDate" class="form-label fw-bold small text-uppercase">Purchase Date</label>
                                <input asp-for="PurchaseDate" class="form-control border-primary shadow-sm rounded-3" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="PurchaseDate" class="text-danger small"></span>
                            </div>
                            <div class="col-12 mt-4 text-end">
                                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 me-2">Cancel</a>
                                <button type="submit" class="btn btn-primary rounded-pill px-5 shadow">Save Stock</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
