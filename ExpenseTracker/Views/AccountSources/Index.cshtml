@model IEnumerable<ExpenseTracker.Models.AccountSource>

@{
    ViewData["Title"] = "Account Sources";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-bank2 me-2 text-primary"></i>Account Sources</h2>
        <a asp-action="Create" class="btn btn-primary rounded-pill fw-bold shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Add New Account
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-borderless align-middle mb-0">
                    <thead class="table-light border-bottom">
                        <tr>
                            <th class="ps-4 py-3">@Html.DisplayNameFor(model => model.Name)</th>
                            <th class="py-3">@Html.DisplayNameFor(model => model.Type)</th>
                            <th class="py-3">@Html.DisplayNameFor(model => model.Balance)</th>
                            <th class="py-3">Interest Rate</th>
                            <th class="text-end pe-4 py-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr class="border-bottom">
                                <td class="ps-4 py-3 fw-semibold">
                                    @Html.DisplayFor(modelItem => item.Name)
                                    @if (!string.IsNullOrEmpty(item.AccountNumber)) {
                                        <div class="text-muted small fw-normal font-monospace">Acct: @item.AccountNumber</div>
                                    }
                                </td>
                                <td class="py-3">
                                    @{
                                        var badgeClass = item.Type switch
                                        {
                                            ExpenseTracker.Models.AccountType.Bank => "bg-success",
                                            ExpenseTracker.Models.AccountType.CreditCard => "bg-warning text-dark",
                                            ExpenseTracker.Models.AccountType.Loan => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge rounded-pill @badgeClass">@item.Type</span>
                                </td>
                                <td class="py-3 font-monospace">
                                    @item.Balance.ToString("C")
                                </td>
                                <td class="py-3">
                                    @if(item.Type == ExpenseTracker.Models.AccountType.Loan && item.InterestRate.HasValue)
                                    {
                                        <span class="text-muted">@item.InterestRate%</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td class="text-end pe-4 py-3">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-circle"><i class="bi bi-pencil"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-circle ms-1"><i class="bi bi-trash"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
