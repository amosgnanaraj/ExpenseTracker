@model List<ExpenseTracker.Models.TechnicalAnalysisResult>

<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th class="ps-4">Symbol</th>
                <th>Price</th>
                <th>SMA 50</th>
                <th>SMA 200</th>
                <th>RSI 14</th>
                <th>MACD Hist</th>
                <th>Analysis Call</th>
                <th class="pe-4">Reasoning</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="8" class="text-center text-muted py-5"><i class="bi bi-info-circle me-2"></i>No analysis available for your current holdings. Ensure symbols are valid.</td></tr>
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td class="ps-4 fw-bold">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                <i class="bi bi-graph-up-arrow"></i>
                            </div>
                            @item.Symbol
                        </div>
                    </td>
                    <td class="fw-semibold">@item.CurrentPrice.ToString("N2")</td>
                    <td>@(item.Sma50?.ToString("N2") ?? "-")</td>
                    <td>@(item.Sma200?.ToString("N2") ?? "-")</td>
                    <td>
                        @{
                            var rsi = item.Rsi14;
                            var rsiClass = rsi < 30 ? "text-success fw-bold" : (rsi > 70 ? "text-danger fw-bold" : "");
                        }
                        <span class="@rsiClass">@(rsi?.ToString("N2") ?? "-")</span>
                    </td>
                    <td>@(item.MacdHistogram?.ToString("N2") ?? "-")</td>
                    <td>
                        @if (item.Recommendation == "Strong Buy") {
                            <span class="badge bg-success rounded-pill px-3 py-2 shadow-sm"><i class="bi bi-rocket-takeoff-fill me-1"></i> STRONG BUY</span>
                        } else if (item.Recommendation == "Buy") {
                            <span class="badge border border-success text-success bg-white rounded-pill px-3 py-2"><i class="bi bi-arrow-up-circle me-1"></i> BUY</span>
                        } else if (item.Recommendation == "Strong Sell") {
                            <span class="badge bg-danger rounded-pill px-3 py-2 shadow-sm"><i class="bi bi-exclamation-octagon-fill me-1"></i> STRONG SELL</span>
                        } else if (item.Recommendation == "Sell") {
                            <span class="badge border border-danger text-danger bg-white rounded-pill px-3 py-2"><i class="bi bi-arrow-down-circle me-1"></i> SELL</span>
                        } else {
                            <span class="badge bg-warning text-dark rounded-pill px-3 py-2"><i class="bi bi-dash-circle me-1"></i> HOLD</span>
                        }
                    </td>
                    <td class="text-muted small pe-4" style="max-width: 250px;">
                        @item.Reason
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
