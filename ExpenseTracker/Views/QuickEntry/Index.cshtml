            // ── Pagination ─────────────────────────────────
            const PAGE_SIZE = 15;
            let currentPage = 1;

            function renderRow(t) {
                let typeBadgeClass = 'bg-secondary', amountClass = 'text-danger', amountPrefix = '-';
                if (t.type === 'Credit')   { typeBadgeClass = 'bg-success'; amountClass = 'text-success'; amountPrefix = '+'; }
                else if (t.type === 'Debit')    { typeBadgeClass = 'bg-danger'; }
                else if (t.type === 'Transfer') { typeBadgeClass = 'bg-info text-dark'; }
                
                const transferInfo = t.transferToName
                    ? `<span class="text-muted small"> → ${t.transferToName}</span>` : '';
                
                const displayAmount = t.isSalary ? '*****' : t.amount;
                const salaryClass = t.isSalary ? 'salary-masked clickable' : '';
                const salaryAttr = t.isSalary ? `data-salary="true" data-id="${t.id}"` : '';

                let categorySubText = '';
                if (t.isSalary && t.salaryMonth && t.salaryYear) {
                    const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
                    categorySubText = ` <span class="badge bg-light text-muted border small">${months[t.salaryMonth - 1]} ${t.salaryYear}</span>`;
                }

                return `<tr class="border-bottom">
                    <td class="ps-4 text-muted small">${t.date}</td>
                    <td><span class="badge rounded-pill ${typeBadgeClass}">${t.type}</span></td>
                    <td><span class="badge bg-light text-dark border">${t.accountName}</span>${transferInfo}</td>
                    <td class="category-cell" data-id="${t.id}" data-category-id="${t.categoryId}">
                        <div class="category-display clickable d-inline-flex align-items-center" title="Click to edit category">
                            <span class="badge bg-light text-primary border category-name-span">${t.categoryName}</span>${categorySubText ? `<span class="ms-1">${categorySubText}</span>` : ''}
                            <i class="bi bi-pencil-square text-muted ms-1 small opacity-50"></i>
                        </div>
                        <div class="category-edit d-none">
                            <select class="form-select form-select-sm inline-category-select">
                                <option value="">Select...</option>
                            </select>
                        </div>
                    </td>
                    <td class="text-truncate" style="max-width:250px;">${t.description}</td>
                    <td class="text-end fw-bold font-monospace ${amountClass} ${salaryClass}" ${salaryAttr}>${amountPrefix}${displayAmount}</td>
                    <td class="text-end pe-4">
                        <button class="btn btn-sm btn-outline-secondary rounded-pill edit-btn" data-id="${t.id}">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger rounded-pill delete-btn" data-id="${t.id}">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>`;
            }

            function loadPage(page) {
                const filters = {
                    page: page,
                    pageSize: PAGE_SIZE,
                    searchTerm: $('#filterSearch').val(),
                    dateFrom: $('#filterDateFrom').val(),
                    dateTo: $('#filterDateTo').val(),
                    type: $('#filterType').val(),
                    categoryId: $('#filterCategory').val(),
                    accountId: $('#filterAccount').val()
                };

                $('#transactionList').html('<tr><td colspan="7" class="text-center py-4 text-muted"><div class="spinner-border spinner-border-sm me-2"></div>Loading...</td></tr>');
                $.get('@Url.Action("GetTransactionsPage", "QuickEntry")', filters, function(data) {
                    currentPage = data.page;
                    const totalPages = Math.max(1, Math.ceil(data.totalCount / PAGE_SIZE));
                    const start = (page - 1) * PAGE_SIZE + 1;
                    const end   = Math.min(page * PAGE_SIZE, data.totalCount);

                    if (data.rows.length === 0) {
                        let msg = data.error ? 'Error: ' + data.error : 'No transactions found.';
                        $('#transactionList').html('<tr><td colspan="7" class="text-center py-4 text-muted">' + msg + '</td></tr>');
                    } else {
                        $('#transactionList').html(data.rows.map(renderRow).join(''));
                    }

                    $('#paginationInfo').text(
                        data.totalCount > 0 ? `Showing ${start}–${end} of ${data.totalCount} transactions` : '0 transactions'
                    );

                    const $c = $('#paginationControls').empty();
                    $c.append(`<li class="page-item ${page<=1?'disabled':''}"><a class="page-link" href="#" data-page="${page-1}">‹</a></li>`);
                    const delta = 2, rs = Math.max(1, page - delta), re = Math.min(totalPages, page + delta);
                    if (rs > 1) {
                        $c.append(`<li class="page-item"><a class="page-link" href="#" data-page="1">1</a></li>`);
                        if (rs > 2) $c.append('<li class="page-item disabled"><span class="page-link">…</span></li>');
                    }
                    for (let i = rs; i <= re; i++) {
                        $c.append(`<li class="page-item ${i===page?'active':''}"><a class="page-link" href="#" data-page="${i}">${i}</a></li>`);
                    }
                    if (re < totalPages) {
                        if (re < totalPages - 1) $c.append('<li class="page-item disabled"><span class="page-link">…</span></li>');
                        $c.append(`<li class="page-item"><a class="page-link" href="#" data-page="${totalPages}">${totalPages}</a></li>`);
                    }
                    $c.append(`<li class="page-item ${page>=totalPages?'disabled':''}"><a class="page-link" href="#" data-page="${page+1}">›</a></li>`);
                });
            }

            $(document).on('click', '#paginationControls a.page-link', function(e) {
                e.preventDefault();
                const p = parseInt($(this).data('page'));
                if (!isNaN(p) && p >= 1) loadPage(p);
